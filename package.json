{
  "name": "atelier-kit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "content:validate": "node scripts/validate-content.js",
    "test": "node --test src/lib/editorial-markup.test.js src/lib/item-images.test.js src/lib/studio-item-gallery.test.js src/lib/site-branding.test.js",
    "item:new": "node scripts/item.js new",
    "item:list": "node scripts/item.js list",
    "item:validate": "node scripts/item.js validate",
    "content:doctor": "node scripts/content-doctor.js",
    "site:scaffold": "node scripts/scaffold-client.js",
    "site:upgrade": "node scripts/site-upgrade.js",
    "site:wizard": "node scripts/site-wizard.js",
    "studio": "node scripts/studio-dev.js",
    "studio:launch": "node scripts/studio-launch.js",
    "publish": "node scripts/publish.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^26.1.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
